<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<!--
    reviews.fxml — Reviews & Feedback page.
    Controller: com.campusflow.controllers.ReviewsController
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.campusflow.controllers.ReviewsController"
      spacing="18" style="-fx-padding: 26; -fx-background-color: #0f172a;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Avis &amp; Feedback"
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;
                          -fx-font-family: Georgia;" />
            <Label text="Retours étudiants et statistiques de satisfaction"
                   style="-fx-font-size: 13; -fx-text-fill: #64748b;" />
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #1e293b; -fx-background-radius: 12;
                 -fx-padding: 12 16 12 16;">
        <Label text="🔍" style="-fx-font-size: 14; -fx-text-fill: #64748b;" />
        <TextField fx:id="searchField" promptText="Rechercher par étudiant, formation, commentaire…"
                   style="-fx-background-color: #0f172a; -fx-border-color: #334155;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-text-fill: #f1f5f9; -fx-prompt-text-fill: #475569;
                          -fx-padding: 9 12 9 12; -fx-font-size: 13;"
                   prefWidth="340" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="countLabel" text="" style="-fx-font-size: 12; -fx-text-fill: #64748b;" />
        <ProgressIndicator fx:id="spinner" prefWidth="22" prefHeight="22" visible="false" />
    </HBox>

    <!-- Main split: table + stats panel -->
    <HBox spacing="18" VBox.vgrow="ALWAYS">

        <!-- Table -->
        <VBox HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #1e293b; -fx-background-radius: 14;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 12, 0, 0, 4);">
            <TableView fx:id="table" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-table-cell-border-color: #334155;" />
        </VBox>

        <!-- Stats sidebar -->
        <VBox spacing="16" prefWidth="280" maxWidth="300"
              style="-fx-background-color: #1e293b; -fx-background-radius: 14;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 12, 0, 0, 4);">

            <Label text="📊  Statistiques"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;" />
            <Separator style="-fx-background-color: #334155;" />

            <!-- Global satisfaction -->
            <VBox spacing="6"
                  style="-fx-background-color: rgba(37,99,235,0.15); -fx-background-radius: 10;
                         -fx-border-color: rgba(37,99,235,0.3); -fx-border-radius: 10;
                         -fx-padding: 14;">
                <Label text="Satisfaction globale"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #60a5fa;" />
                <Label fx:id="globalSatLabel" text="…"
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2563eb;" />
                <Label text="Basé sur tous les avis étudiants"
                       style="-fx-font-size: 11; -fx-text-fill: #3b82f6;" />
            </VBox>

            <!-- Per-course breakdown (populated by controller) -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="statsPanel" spacing="4" />
            </ScrollPane>

        </VBox>
    </HBox>

</VBox>
