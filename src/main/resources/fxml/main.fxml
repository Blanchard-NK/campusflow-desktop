<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
    main.fxml — CampusFlow Application Shell
    Dark sidebar + topbar + dynamic content pane.
    Controller: com.campusflow.controllers.MainController
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campusflow.controllers.MainController"
            stylesheets="@/styles/app.css"
            style="-fx-background-color: #0f172a;"
            prefWidth="1280" prefHeight="780">

    <!-- ══════════════════════════════════════════════════════
         LEFT — SIDEBAR
    ══════════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="230" minWidth="230" maxWidth="230"
              style="-fx-background-color: #111827;">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 22 18 18 18; -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 0 0 1 0;">
                <Label text="🎓"
                       style="-fx-background-color: linear-gradient(to bottom right,#3b82f6,#06b6d4);
                               -fx-background-radius: 8; -fx-padding: 6 10 6 10; -fx-font-size: 17;" />
                <Label text="CampusFlow"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;" />
            </HBox>

            <!-- Navigation -->
            <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 10 10 10 10;" spacing="2">

                <!-- Section: Général -->
                <Label text="GÉNÉRAL"
                       style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #334155;
                              -fx-letter-spacing: 0.12em; -fx-padding: 10 8 4 8;" />

                <VBox fx:id="navDashboard" styleClass="nav-item"
                      onMouseClicked="#onNavDashboard">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 9 10 9 10;">
                        <Label text="📊" style="-fx-font-size: 14;" />
                        <Label text="Tableau de bord" styleClass="nav-label" />
                    </HBox>
                </VBox>

                <!-- Section: Académique -->
                <Label text="ACADÉMIQUE"
                       style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #334155;
                              -fx-letter-spacing: 0.12em; -fx-padding: 14 8 4 8;" />

                <VBox fx:id="navStudents" styleClass="nav-item"
                      onMouseClicked="#onNavStudents">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 9 10 9 10;">
                        <Label text="👥" style="-fx-font-size: 14;" />
                        <Label text="Étudiants" styleClass="nav-label" />
                    </HBox>
                </VBox>

                <VBox fx:id="navTeachers" styleClass="nav-item"
                      onMouseClicked="#onNavTeachers">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 9 10 9 10;">
                        <Label text="👨‍🏫" style="-fx-font-size: 14;" />
                        <Label text="Enseignants" styleClass="nav-label" />
                    </HBox>
                </VBox>

                <VBox fx:id="navCourses" styleClass="nav-item"
                      onMouseClicked="#onNavCourses">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 9 10 9 10;">
                        <Label text="📚" style="-fx-font-size: 14;" />
                        <Label text="Formations" styleClass="nav-label" />
                    </HBox>
                </VBox>

                <VBox fx:id="navReviews" styleClass="nav-item"
                      onMouseClicked="#onNavReviews">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 9 10 9 10;">
                        <Label text="⭐" style="-fx-font-size: 14;" />
                        <Label text="Avis &amp; Feedback" styleClass="nav-label" />
                    </HBox>
                </VBox>

                <!-- Spacer -->
                <Region VBox.vgrow="ALWAYS" />

                <!-- Section: Compte -->
                <Label text="COMPTE"
                       style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #334155;
                              -fx-letter-spacing: 0.12em; -fx-padding: 8 8 4 8;" />

                <VBox styleClass="nav-item" onMouseClicked="#onLogout">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 9 10 9 10;">
                        <Label text="🚪" style="-fx-font-size: 14;" />
                        <Label text="Déconnexion" styleClass="nav-label" />
                    </HBox>
                </VBox>

            </VBox>

            <!-- User footer -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 14 14 14 14; -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1 0 0 0; -fx-cursor: hand;"
                  onMouseClicked="#onLogout">

                <StackPane style="-fx-background-color: #2563eb; -fx-background-radius: 99; -fx-min-width: 36; -fx-min-height: 36; -fx-max-width: 36; -fx-max-height: 36;">
                    <Label fx:id="userInitialsLabel" text="AD"
                           style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: white;" />
                </StackPane>

                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Label fx:id="userNameLabel" text="Admin Dupont"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;" />
                    <Label fx:id="userRoleLabel" text="Administrateur"
                           style="-fx-font-size: 10; -fx-text-fill: #475569;" />
                </VBox>

                <Label text="⋮" style="-fx-text-fill: #475569; -fx-font-size: 14;" />
            </HBox>

        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════════════
         CENTER — TOPBAR + CONTENT + STATUS BAR
    ══════════════════════════════════════════════════════ -->
    <center>
        <VBox>

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="60"
                  style="-fx-background-color: #1e293b; -fx-padding: 0 26 0 26;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 6, 0, 0, 2);">

                <Label fx:id="breadcrumbLabel" text="🏠  Tableau de bord"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="🔔" styleClass="btn-icon"
                        onAction="#onNavDashboard" />

                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 10;
                             -fx-padding: 6 14 6 14; -fx-cursor: hand;"
                      onMouseClicked="#onLogout">
                    <Label fx:id="userNameLabel" text="Admin Dupont"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;" />
                    <StackPane style="-fx-background-color: #2563eb; -fx-background-radius: 99;
                                      -fx-min-width: 30; -fx-min-height: 30; -fx-max-width: 30; -fx-max-height: 30;">
                        <Label fx:id="userInitialsLabel" text="AD"
                               style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: white;" />
                    </StackPane>
                </HBox>
            </HBox>

            <!-- DYNAMIC CONTENT AREA -->
            <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #0f172a;" />

            <!-- STATUS BAR -->
            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="30"
                  style="-fx-background-color: #1e293b; -fx-padding: 0 16 0 16;
                         -fx-border-color: #334155; -fx-border-width: 1 0 0 0;">
                <Label text="●" style="-fx-text-fill: #10b981; -fx-font-size: 9;" />
                <Label fx:id="statusLabel" text="Prêt"
                       style="-fx-font-size: 11; -fx-text-fill: #64748b;" />
                <Region HBox.hgrow="ALWAYS" />
                <ProgressBar fx:id="globalProgressBar" prefWidth="100" prefHeight="5"
                             style="-fx-accent: #2563eb;" visible="false" />
                <Label text="CampusFlow v1.0.0"
                       style="-fx-font-size: 11; -fx-text-fill: #334155;" />
            </HBox>

        </VBox>
    </center>

</BorderPane>
