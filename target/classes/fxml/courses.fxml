<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<!--
    courses.fxml — Courses / Formations page.
    Controller: com.campusflow.controllers.CoursesController
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.campusflow.controllers.CoursesController"
      spacing="18" style="-fx-padding: 26; -fx-background-color: #0f172a;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Formations"
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;
                          -fx-font-family: Georgia;" />
            <Label text="BTS · Bachelor · Licence · Master"
                   style="-fx-font-size: 13; -fx-text-fill: #64748b;" />
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #1e293b; -fx-background-radius: 12;
                 -fx-padding: 14 18 14 18;">
        <TextField fx:id="searchField" promptText="🔍  Rechercher une formation…"
                   style="-fx-background-color: #0f172a; -fx-border-color: #334155;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-text-fill: #f1f5f9; -fx-prompt-text-fill: #475569;
                          -fx-padding: 9 12 9 12; -fx-font-size: 13;"
                   prefWidth="250" />
        <ComboBox fx:id="levelFilter" prefWidth="150"
                  style="-fx-background-color: #0f172a; -fx-border-color: #334155;
                         -fx-border-radius: 8; -fx-background-radius: 8;
                         -fx-text-fill: #f1f5f9; -fx-font-size: 13;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="countLabel" text="" style="-fx-font-size: 12; -fx-text-fill: #64748b;" />
        <ProgressIndicator fx:id="spinner" prefWidth="22" prefHeight="22" visible="false" />
    </HBox>

    <!-- Card grid inside scroll pane -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <FlowPane fx:id="cardGrid" hgap="16" vgap="16"
                  style="-fx-padding: 4; -fx-background-color: transparent;" />
    </ScrollPane>

</VBox>
